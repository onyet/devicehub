{
  "name": "devicehub",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial desktop directory for official device recovery portals.",
  "type": "module",
  "main": "src/main/index.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && node scripts/start_electron.cjs .\"",
    "dev:renderer": "vite",
    "start": "node scripts/start_electron.cjs .",
    "build": "vite build",
    "package": "npm run build && electron-builder",
    "check:links": "node scripts/link_checker.js"
  },
  "build": {
    "appId": "id.devicehub.app",
    "productName": "DeviceHub",
    "files": [
      "dist/**",
      "src/main/**",
      "src/preload/**",
      "src/data/**",
      "icons/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^40.0.0",
    "electron-builder": "^26.15.3",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
